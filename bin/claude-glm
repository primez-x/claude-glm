#!/usr/bin/env bash
set -euo pipefail
export PATH="$HOME/.local/bin:$HOME/bin:$PATH"

skip_tmux=0
force_new_tmux=0
claude_glm_args=()
while (($#)); do
  case "$1" in
    --no-tmux)
      skip_tmux=1
      shift
      ;;
    --new-tmux)
      force_new_tmux=1
      shift
      ;;
    *)
      claude_glm_args+=("$1")
      shift
      ;;
  esac
done
set -- "${claude_glm_args[@]}"

env_file="${CLAUDE_GLM_ENV_FILE:-$HOME/.config/claude-glm/env}"
if [[ ! -f "$env_file" ]]; then
  printf 'Missing Claude-GLM env file: %s\n' "$env_file" >&2
  exit 2
fi
# shellcheck source=/dev/null
source "$env_file"
if [[ -n "${ANTHROPIC_AUTH_TOKEN:-}" ]]; then
  # Prefer provider-native Claude Code auth. Exporting ANTHROPIC_API_KEY here
  # makes interactive Claude Code treat this as a custom API-key session.
  unset ANTHROPIC_API_KEY
elif [[ -z "${ANTHROPIC_API_KEY:-}" ]]; then
  printf 'Missing ANTHROPIC_AUTH_TOKEN or ANTHROPIC_API_KEY in %s
' "$env_file" >&2
  exit 2
fi
prompt_file="${CLAUDE_GLM_SYSTEM_PROMPT_FILE:-$HOME/.claude/prompts/fable-provider-native-system.md}"
if [[ ! -f "$prompt_file" ]]; then
  printf 'Missing Claude-GLM system prompt file: %s
' "$prompt_file" >&2
  exit 2
fi

tmux_session_prefix="${CLAUDE_GLM_TMUX_SESSION_PREFIX:-claude-glm}"

tmux_session_part() {
  local value="${1:-session}"
  value="${value//[^[:alnum:]_.-]/-}"
  value="${value#-}"
  value="${value%-}"
  printf '%s' "${value:-session}"
}

script_path="${BASH_SOURCE[0]}"
if command -v realpath >/dev/null 2>&1; then
  script_path="$(realpath "$script_path")"
fi

session_matches_claude_glm() {
  local session_name="$1"
  local pane_command="$2"
  local pane_tty="$3"
  local process_args

  if [[ "$session_name" == "$tmux_session_prefix"* ]]; then
    return 0
  fi

  if [[ "$pane_command" != "claude" && "$pane_command" != "node" ]]; then
    return 1
  fi

  process_args="$(ps -t "$pane_tty" -o args= 2>/dev/null || true)"
  [[ "$process_args" == *"--system-prompt-file"* && "$process_args" == *"$prompt_file"* ]]
}

collect_claude_glm_sessions() {
  local session_name attached windows pane_command pane_path pane_tty
  declare -A seen_sessions=()
  claude_glm_tmux_sessions=()

  while IFS='|' read -r session_name attached windows pane_command pane_path pane_tty; do
    [[ -n "${session_name:-}" ]] || continue
    [[ -z "${seen_sessions[$session_name]:-}" ]] || continue
    if session_matches_claude_glm "$session_name" "$pane_command" "$pane_tty"; then
      seen_sessions["$session_name"]=1
      claude_glm_tmux_sessions+=(
        "${session_name}"$'\t'"${attached}"$'\t'"${windows}"$'\t'"${pane_command}"$'\t'"${pane_path}"
      )
    fi
  done < <(tmux list-panes -a -F '#{session_name}|#{session_attached}|#{session_windows}|#{pane_current_command}|#{pane_current_path}|#{pane_tty}' 2>/dev/null || true)
}

attach_tmux_session() {
  local entry="$1"
  local session_name
  IFS=$'\t' read -r session_name _ <<<"$entry"
  exec tmux attach-session -t "$session_name"
}

start_tmux_session() {
  local cwd_slug stamp session_name command_text
  local command_parts
  cwd_slug="$(tmux_session_part "$(basename "$PWD")")"
  stamp="$(date +%Y%m%d-%H%M%S)"
  session_name="${tmux_session_prefix}-${cwd_slug}-${stamp}"
  while tmux has-session -t "$session_name" 2>/dev/null; do
    session_name="${tmux_session_prefix}-${cwd_slug}-${stamp}-${RANDOM}"
  done

  command_parts=(env "HOME=$HOME" "CLAUDE_GLM_TMUX_SESSION=$session_name")
  if [[ -n "${CLAUDE_GLM_ENV_FILE:-}" ]]; then
    command_parts+=("CLAUDE_GLM_ENV_FILE=$CLAUDE_GLM_ENV_FILE")
  fi
  if [[ -n "${CLAUDE_GLM_SYSTEM_PROMPT_FILE:-}" ]]; then
    command_parts+=("CLAUDE_GLM_SYSTEM_PROMPT_FILE=$CLAUDE_GLM_SYSTEM_PROMPT_FILE")
  fi
  command_parts+=("$script_path" --no-tmux "$@")
  printf -v command_text '%q ' "${command_parts[@]}"
  command_text="${command_text% }"
  exec tmux new-session -s "$session_name" -c "$PWD" "$command_text"
}

prompt_for_tmux_session() {
  local count="$1"
  local index entry session_name attached windows pane_command pane_path state choice
  shift

  printf 'Existing Claude-GLM tmux sessions:\n' >&2
  for index in "${!claude_glm_tmux_sessions[@]}"; do
    entry="${claude_glm_tmux_sessions[$index]}"
    IFS=$'\t' read -r session_name attached windows pane_command pane_path <<<"$entry"
    if [[ "${attached:-0}" == "0" ]]; then
      state="detached"
    else
      state="attached:${attached}"
    fi
    printf '  %d) %s [%s, %s window(s), %s, %s]\n' \
      "$((index + 1))" "$session_name" "$state" "${windows:-?}" "${pane_command:-?}" "${pane_path:-?}" >&2
  done
  printf '  n) start a new Claude-GLM tmux session\n' >&2

  while true; do
    if ((count == 1)); then
      printf 'Attach/continue session 1 or start new [n]: ' >&2
    else
      printf 'Attach/continue session 1-%d or start new [n]: ' "$count" >&2
    fi
    IFS= read -r choice
    case "$choice" in
      ""|n|N|new|NEW)
        start_tmux_session "$@"
        ;;
      q|Q|quit|QUIT)
        exit 0
        ;;
      *[!0-9]*)
        printf 'Enter a number, n, or q.\n' >&2
        ;;
      *)
        if ((choice >= 1 && choice <= count)); then
          attach_tmux_session "${claude_glm_tmux_sessions[$((choice - 1))]}"
        fi
        printf 'Enter a number from 1 to %d, n, or q.\n' "$count" >&2
        ;;
    esac
  done
}

should_use_tmux() {
  [[ "$skip_tmux" == "0" ]] || return 1
  [[ "${CLAUDE_GLM_NO_TMUX:-}" != "1" ]] || return 1
  [[ "${CLAUDE_GLM_TMUX:-}" != "0" ]] || return 1
  [[ -z "${TMUX:-}" ]] || return 1
  [[ -t 0 && -t 1 ]] || return 1
  command -v tmux >/dev/null 2>&1 || return 1
  return 0
}

if should_use_tmux; then
  declare -a claude_glm_tmux_sessions
  collect_claude_glm_sessions
  if ((force_new_tmux == 0)); then
    if ((${#claude_glm_tmux_sessions[@]} >= 1)); then
      prompt_for_tmux_session "${#claude_glm_tmux_sessions[@]}" "$@"
    fi
  fi
  start_tmux_session "$@"
fi

has_model=0
has_skip_permissions=0
for arg in "$@"; do
  case "$arg" in
    --model|--model=*) has_model=1 ;;
    --dangerously-skip-permissions) has_skip_permissions=1 ;;
  esac
done
claude_args=(--system-prompt-file "$prompt_file")
if [[ "$has_skip_permissions" == "0" ]]; then
  claude_args+=(--dangerously-skip-permissions)
fi
if [[ "$has_model" == "0" ]]; then
  claude_args+=(--model opus)
fi
claude_args+=("$@")
export CLAUDE_GLM_WRAPPER=1
exec claude "${claude_args[@]}"
